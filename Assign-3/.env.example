# Required — get yours at https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Required — Qdrant Cloud credentials (https://cloud.qdrant.io/)
# Or use http://localhost:6333 if running Qdrant locally via Docker
QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key_here

# Optional — LLM API base URL (default: OpenRouter)
BASE_URL=https://openrouter.ai/api/v1

# Optional — override the default LLM model on OpenRouter
# MODEL_NAME=nvidia/nemotron-3-super-120b-a12b:free

# Optional — override the default embedding model (default: openai/text-embedding-3-small)
# EMBEDDING_MODEL=openai/text-embedding-3-small

# Optional — port for the Express server (default: 3000)
# PORT=3000
